{
  "id": null,
  "uid": "system-health",
  "title": "System Health",
  "tags": ["system", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "WebSocket Connected",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "producer_websocket_connected" }
      ]
    },
    {
      "id": 2,
      "title": "WebSocket Reconnects (total)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "producer_websocket_reconnects_total" }
      ]
    },
    {
      "id": 3,
      "title": "Published msgs/sec",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 1 }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "rate(producer_messages_published_total[1m])" }
      ]
    },
    {
      "id": 4,
      "title": "Rows committed/sec",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 1 }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "rate(consumer_rows_committed_total[1m])" }
      ]
    },
    {
      "id": 5,
      "title": "Throughput",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "showLegend": true } },
      "targets": [
        { "refId": "A", "expr": "rate(producer_messages_published_total[1m])", "legendFormat": "produced" },
        { "refId": "B", "expr": "rate(consumer_messages_consumed_total[1m])", "legendFormat": "consumed" },
        { "refId": "C", "expr": "rate(consumer_rows_committed_total[1m])", "legendFormat": "rows committed" }
      ]
    },
    {
      "id": 6,
      "title": "Flush Latency (TimescaleDB)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "showLegend": true } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, rate(consumer_flush_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, rate(consumer_flush_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, rate(consumer_flush_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 7,
      "title": "Resident Memory",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "showLegend": true } },
      "targets": [
        { "refId": "A", "expr": "producer_resident_memory_bytes", "legendFormat": "producer" },
        { "refId": "B", "expr": "consumer_resident_memory_bytes", "legendFormat": "consumer" }
      ]
    },
    {
      "id": 8,
      "title": "Errors (total)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "showLegend": true } },
      "targets": [
        { "refId": "A", "expr": "producer_parse_errors_total", "legendFormat": "producer parse errors" },
        { "refId": "B", "expr": "consumer_parse_errors_total", "legendFormat": "consumer parse errors" },
        { "refId": "C", "expr": "consumer_flush_errors_total", "legendFormat": "consumer flush errors" }
      ]
    },
    {
      "id": 9,
      "title": "Consumer Batch Fill",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20 } },
        "overrides": []
      },
      "options": { "legend": { "showLegend": true } },
      "targets": [
        { "refId": "A", "expr": "consumer_batch_fill", "legendFormat": "rows buffered" }
      ]
    }
  ]
}
